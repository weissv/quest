datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

enum CohortType {
  GRADE_1_4
  GRADE_5_8
}

enum ParentRole {
  MAMA
  PAPA
  OTHER
}

enum EvaluationStatus {
  APPROVED
  REJECTED
  GREY_ZONE
  PENDING
  REVIEW
  INTERVIEW
}

model Question {
  id         String      @id @default(uuid())
  code       String?     @unique
  block      String
  cohort     CohortType?
  type       String
  text       String
  options    Json?
  dependsOn  Json?
  mirrorText String?
  position   Json?
  createdAt  DateTime    @default(now())
}

model Result {
  id          String            @id @default(uuid())
  familyCode  String?
  parentRole  ParentRole?
  cohort      CohortType?
  answers     Json
  sjtScore    Float             @default(0)
  aiScore     Float?
  totalScore  Float             @default(0)
  status      String
  evalStatus  EvaluationStatus?
  aiAnalysis  Json?
  aiReasoning String?
  dyadMetrics Json?
  createdAt   DateTime          @default(now())

  @@index([familyCode])
}

model Setting {
  key   String @id
  value String
}
